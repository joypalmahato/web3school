# ============================================================
# WEB3SCHOOL — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# InsForge (required — backend)
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-project.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-anon-key
INSFORGE_API_KEY=your-api-key

# Groq API (required — replaces Anthropic)
GROQ_API_KEY=gsk_your-key

# Resend — Transactional Emails (optional, emails skip if not set)
RESEND_API_KEY=re_your-key

# PostHog — Analytics (optional, analytics skip if not set)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Web3School

# Admin (comma-separated emails with approval access)
ADMIN_EMAILS=your@email.com
