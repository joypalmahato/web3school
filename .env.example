# ============================================================
# WEB3SCHOOL — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — Claude API (required)
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Resend — Transactional Emails (optional, emails skip if not set)
RESEND_API_KEY=re_your-key

# PostHog — Analytics (optional, analytics skip if not set)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Web3School
